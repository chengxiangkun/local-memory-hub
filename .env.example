# Local Memory Hub 环境变量示例
# 复制为 .env.local 后填写真实值(.env.local 已 gitignore,不会进 Git)。
# 提示:连接器凭证也可在「导入中心 → 凭证配置」里加密填写,无需手改本文件。

# ---- 飞书 ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 可选:测试用文档/文件夹链接
FEISHU_TEST_DOC_URL=
FEISHU_TEST_FOLDER_URL=

# ---- 腾讯文档 ----
# 在 docs.qq.com/open 控制台获取;access_token 约 30 天有效,过期需重置后更新
TENCENT_CLIENT_ID=
TENCENT_ACCESS_TOKEN=
TENCENT_OPEN_ID=

# ---- 可选:覆盖默认数据目录 / 端口 ----
# LMH_DATA_DIR=/path/to/data
# LMH_NODE=/usr/local/bin/node
