{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalMemoryHub",
  "version": "0.0.1",
  "identifier": "com.localmemoryhub.desktop",
  "build": {
    "beforeDevCommand": "npm start",
    "devUrl": "http://127.0.0.1:3100",
    "frontendDist": "http://127.0.0.1:3100"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Local Memory Hub",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
